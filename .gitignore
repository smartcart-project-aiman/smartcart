node_modules/
dist/
build/
.next/
.nuxt/
.cache/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─── Python ───────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
.env/
*.egg-info/
dist/
.pytest_cache/
.coverage
htmlcov/
.ruff_cache/
mlruns/
mlartifacts/

# ─── Docker ───────────────────────────────────────────────────────
.dockerignore

